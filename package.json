{
  "name": "autodocs-engine",
  "version": "0.9.9",
  "description": "Codebase intelligence engine for generating AI context files",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "autodocs-engine": "dist/bin/autodocs-engine.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/msiric/autodocs-engine"
  },
  "keywords": [
    "agents-md",
    "claude-md",
    "cursorrules",
    "ai-context",
    "codebase-intelligence",
    "typescript",
    "ast",
    "conventions"
  ],
  "homepage": "https://github.com/msiric/autodocs-engine#readme",
  "bugs": {
    "url": "https://github.com/msiric/autodocs-engine/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dead-code": "knip",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "mri": "^1.2.0",
    "picomatch": "^4.0.0",
    "typescript": "^5.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
